{
  "name": "shibui-code-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "lint": "npm run typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:contract": "vitest run src/__tests__/native.test.ts src/__tests__/bridge-contract.test.ts",
    "test:coverage": "vitest run --coverage",
    "dev:e2e-server": "vite preview --host 127.0.0.1 --port 4173 --strictPort",
    "e2e:install": "node ../scripts/run-playwright.mjs install",
    "test:e2e": "node ../scripts/run-playwright.mjs test"
  },
  "dependencies": {
    "@lezer/highlight": "^1.0.0",
    "@codemirror/commands": "^6.0.0",
    "@codemirror/lang-cpp": "^6.0.0",
    "@codemirror/lang-css": "^6.0.0",
    "@codemirror/lang-go": "^6.0.0",
    "@codemirror/lang-html": "^6.0.0",
    "@codemirror/lang-java": "^6.0.0",
    "@codemirror/lang-javascript": "^6.0.0",
    "@codemirror/lang-json": "^6.0.0",
    "@codemirror/lang-markdown": "^6.0.0",
    "@codemirror/lang-python": "^6.0.0",
    "@codemirror/lang-rust": "^6.0.0",
    "@codemirror/legacy-modes": "^6.0.0",
    "@codemirror/language": "^6.0.0",
    "@codemirror/lint": "^6.0.0",
    "@codemirror/state": "^6.0.0",
    "@codemirror/view": "^6.0.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "1.6.1",
    "@types/node": "^20.0.0",
    "jsdom": "^24.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
